<% layout('layout') %>

<link href="/css/dora-dashboard.css" rel="stylesheet">

<div class="dora-dashboard">
  <!-- Header -->
  <div class="dora-header">
    <h1>DORA Metrics Dashboard</h1>
    <p class="lead">Software delivery performance metrics based on the DORA (DevOps Research and Assessment) framework</p>
  </div>

  <!-- Period Selector -->
  <div class="period-selector">
    <span style="margin-right: 10px; font-weight: 600; color: #555;">Period:</span>
    <button class="btn btn-default period-btn" data-days="30">30 Days</button>
    <button class="btn btn-default period-btn active" data-days="90">90 Days</button>
    <button class="btn btn-default period-btn" data-days="180">180 Days</button>
  </div>

  <!-- Loading State -->
  <div id="dora-loading" class="dora-loading">
    <span class="glyphicon glyphicon-refresh"></span>
    <p>Loading DORA metrics from GitHub...</p>
  </div>

  <!-- Error State -->
  <div id="dora-error" class="dora-error" style="display: none;">
    <span class="glyphicon glyphicon-exclamation-sign"></span>
    <p class="error-message">Failed to load metrics</p>
    <button class="btn btn-default" onclick="location.reload()">Retry</button>
  </div>

  <!-- Metrics Content -->
  <div id="dora-metrics-content" style="display: none;">

    <!-- Metric Cards Row -->
    <div class="row">
      <!-- Deployment Frequency -->
      <div class="col-md-3 col-sm-6 metric-card" id="deployment-frequency">
        <div class="panel panel-default">
          <div class="panel-heading">
            <span class="glyphicon glyphicon-upload"></span> Deployment Frequency
          </div>
          <div class="panel-body text-center">
            <span class="rating-badge">-</span>
            <div class="metric-value">-</div>
            <p class="metric-description">-</p>
          </div>
        </div>
      </div>

      <!-- Lead Time for Changes -->
      <div class="col-md-3 col-sm-6 metric-card" id="lead-time">
        <div class="panel panel-default">
          <div class="panel-heading">
            <span class="glyphicon glyphicon-time"></span> Lead Time for Changes
          </div>
          <div class="panel-body text-center">
            <span class="rating-badge">-</span>
            <div class="metric-value">-</div>
            <p class="metric-description">-</p>
          </div>
        </div>
      </div>

      <!-- Change Failure Rate -->
      <div class="col-md-3 col-sm-6 metric-card" id="change-failure-rate">
        <div class="panel panel-default">
          <div class="panel-heading">
            <span class="glyphicon glyphicon-alert"></span> Change Failure Rate
          </div>
          <div class="panel-body text-center">
            <span class="rating-badge">-</span>
            <div class="metric-value">-</div>
            <p class="metric-description">-</p>
          </div>
        </div>
      </div>

      <!-- Mean Time to Recovery -->
      <div class="col-md-3 col-sm-6 metric-card" id="mttr">
        <div class="panel panel-default">
          <div class="panel-heading">
            <span class="glyphicon glyphicon-wrench"></span> Mean Time to Recovery
          </div>
          <div class="panel-body text-center">
            <span class="rating-badge">-</span>
            <div class="metric-value">-</div>
            <p class="metric-description">-</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Charts Row -->
    <div class="row">
      <div class="col-md-6 chart-container">
        <div class="panel panel-default">
          <div class="panel-heading">Deployment Frequency</div>
          <div class="panel-body">
            <div class="chart-wrapper">
              <canvas id="chart-deployment-frequency"></canvas>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-6 chart-container">
        <div class="panel panel-default">
          <div class="panel-heading">Lead Time for Changes</div>
          <div class="panel-body">
            <div class="chart-wrapper">
              <canvas id="chart-lead-time"></canvas>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-md-6 chart-container">
        <div class="panel panel-default">
          <div class="panel-heading">Change Failure Rate</div>
          <div class="panel-body">
            <div class="chart-wrapper">
              <canvas id="chart-change-failure-rate"></canvas>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-6 chart-container">
        <div class="panel panel-default">
          <div class="panel-heading">Mean Time to Recovery</div>
          <div class="panel-body">
            <div class="chart-wrapper">
              <canvas id="chart-mttr"></canvas>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="dora-footer">
      <span id="dora-period-info"></span> &bull;
      <span id="dora-generated-at"></span> &bull;
      Data source: GitHub Deployments API
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script src="/js/dora-charts.js"></script>
